{
  "name": "perspective-core",
  "version": "0.1.0",
  "description": "Self-learning execution layer for agents and automation. Wraps any execution engine with memory, telemetry, and cross-run policy learning.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "slc": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsx scripts/e2e-learning-loop.ts",
    "debug:persona": "tsx scripts/planetary-persona-debug.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.ts"
  },
  "keywords": [
    "self-learning",
    "execution-layer",
    "agent-framework",
    "automation",
    "orchestrator",
    "memory",
    "telemetry",
    "policy-learning",
    "fix-recipes",
    "error-recovery",
    "ai-agent",
    "self-healing",
    "ci-cd",
    "devops",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DDMX2022/perspective-core.git"
  },
  "homepage": "https://github.com/DDMX2022/perspective-core#readme",
  "bugs": {
    "url": "https://github.com/DDMX2022/perspective-core/issues"
  },
  "author": "DDMX2022",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.5",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
